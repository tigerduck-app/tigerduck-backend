# =============================================================================
# TigerDuck backend — .env template
# =============================================================================
# Copy this file to .env at the repo root and fill in real values. The real
# file is gitignored. Every key is read via pydantic-settings with prefix
# TIGERDUCK_ (see server/config.py).
#
# Defaults are tuned for LOCAL DEVELOPMENT — TIGERDUCK_ENV=development means
# ./start.sh auto-loads docker-compose.dev.yml (publishes port 40000 to the
# host, drops the prod-only proxy-net). See docs/local-dev-backend.md.
#
# Production deployment:
#   1. Flip TIGERDUCK_ENV to "production" (skips the dev override).
#   2. Fill POSTGRES_PASSWORD (referenced by docker-compose.yml).
#   3. Put APNs .p8 at server/secrets/AuthKey_<KEY_ID>.p8.
#   4. `./start.sh` — the prod compose file routes the backend through
#      nginx-proxy-manager via proxy-net (must exist as an external network).
# =============================================================================

# --- Compose-only (interpolated at `docker compose up` time) -----------------
# Referenced by docker-compose.yml as ${POSTGRES_PASSWORD}. Must match the
# password portion of TIGERDUCK_DATABASE_URL below.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE_32

# --- Environment ----------------------------------------------------------
# "development" → start.sh auto-loads docker-compose.dev.yml.
# "production"  → only docker-compose.yml is loaded (NPM-fronted deploy).
# Any other value falls through to production behaviour, by design — we
# don't want a typo to silently expose the backend port on a prod host.
TIGERDUCK_ENV=development
TIGERDUCK_LOG_LEVEL=DEBUG

# --- Database ------------------------------------------------------------
# Host `tigerduck-db` resolves via Docker DNS on the tigerduck-db network.
# POSTGRES_PASSWORD must match whatever docker-compose.yml gives postgres.
TIGERDUCK_DATABASE_URL=postgresql+asyncpg://tigerduck:CHANGE_ME_POSTGRES_PASSWORD@tigerduck-db:5432/tigerduck

# --- LLM (llama-server on the host, reached via host.docker.internal) ---
# llama-server runs native (Metal GPU); the backend container reaches it via
# Docker Desktop's host-gateway alias. Port matches deploy/launchd/ai.tigerduck.llm.plist.
TIGERDUCK_LLM_BASE_URL=http://host.docker.internal:40001/v1
TIGERDUCK_LLM_API_KEY=sk-local
TIGERDUCK_LLM_MODEL=gemma-4-e4b-it
# Default 120s is set in server/config.py. Uncomment to override.
# TIGERDUCK_LLM_TIMEOUT_SECONDS=240
# Dev-only: skip the 60s LLM-ready probe at server.startup so the API is
# up immediately even when llama-server isn't running. Bulletin
# classification will silently no-op until llama-server comes back. Do
# NOT set true in production.
# TIGERDUCK_SKIP_LLM_PROBE=true

# --- APNs ----------------------------------------------------------------
TIGERDUCK_APNS_KEY_ID=CHANGE_ME
TIGERDUCK_APNS_TEAM_ID=CHANGE_ME
TIGERDUCK_APNS_BUNDLE_ID=org.ntust.app.TigerDuck
# "development" = api.sandbox.push.apple.com (Xcode debug builds).
# "production"  = api.push.apple.com (TestFlight / App Store).
TIGERDUCK_APNS_ENV=development
# Path is relative to the process CWD (the container WORKDIR = /app).
TIGERDUCK_APNS_KEY_PATH=server/secrets/AuthKey_CHANGE_ME.p8

# --- FCM (Android push) --------------------------------------------------
# Drop the Firebase service-account JSON at the path below. When project_id
# or credentials_path is missing, fcm_client.build_sender() returns
# RecordingFcmSender and Android pushes are silently no-ops.
TIGERDUCK_FCM_PROJECT_ID=CHANGE_ME_FIREBASE_PROJECT_ID
TIGERDUCK_FCM_CREDENTIALS_PATH=server/secrets/fcm_service_account.json
# Per-batch send timeout. firebase-admin's `send_each_for_multicast` opens
# parallel TLS handshakes per token and the first cold batch also pays for
# OAuth-token mint, so the default 15s can blow up on the first dispatch
# tick after server start. 30s leaves headroom; warm batches finish in <1s.
TIGERDUCK_FCM_SEND_TIMEOUT_SECONDS=30

# --- Bulletin pipeline ----------------------------------------------------
# Optional PEM bundle containing NTUST's root + intermediates. When present
# and readable, the scraper/backfill client validates TLS against it; when
# absent, it falls back to verify=False and logs a one-time warning (MVP
# default). To build the bundle:
#   openssl s_client -showcerts -connect bulletin.ntust.edu.tw:443 </dev/null \
#     | sed -n '/BEGIN CERT/,/END CERT/p' > ntust_bundle.pem
#   # repeat for obei / admissions / library subdomains and concat.
# TIGERDUCK_BULLETIN_CA_BUNDLE=server/secrets/ntust_bundle.pem

# --- API auth ------------------------------------------------------------
# Shared secret checked on every write endpoint via the X-Push-Token header.
# Both iOS and Android clients send this same value — the backend has one
# secret, not per-platform. Empty = auth disabled (NEVER in production).
#   iOS:     Info.plist key TigerDuckAPIToken (swift/TigerDuck/Secrets.xcconfig).
#   Android: local.properties (mirror this exact value).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TIGERDUCK_API_SHARED_SECRET=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE_32

# --- Bulletin dispatch ---------------------------------------------------
# Default 60s is set in server/config.py. Lower it for live testing.
# TIGERDUCK_BULLETIN_DISPATCH_INTERVAL_SECONDS=60

# --- Portal ---------------------------------------------------------------
# Public URLs surfaced on the portal status page (and used by anything
# else that wants a clickable backend / portal link). Defaults match
# what start.sh prints: localhost ports in dev, proxy-net internal
# hostnames in prod. Override in production to point at your public DNS.
# TIGERDUCK_BACKEND_PUBLIC_URL=https://api.tigerduck.app
# TIGERDUCK_PORTAL_PUBLIC_URL=https://portal.tigerduck.app
