# Copy to backend/.env and fill in. Never commit the real .env.

TIGERDUCK_ENV=development
TIGERDUCK_LOG_LEVEL=INFO

# Postgres (matches docker-compose.yml defaults)
TIGERDUCK_DATABASE_URL=postgresql+asyncpg://tigerduck:tigerduck@localhost:5432/tigerduck

# APNs — required before Checkpoint 3 real push tests.
# Create at https://developer.apple.com/account/resources/authkeys/list
TIGERDUCK_APNS_BUNDLE_ID=org.ntust.app.TigerDuck
TIGERDUCK_APNS_TEAM_ID=
TIGERDUCK_APNS_KEY_ID=
TIGERDUCK_APNS_KEY_PATH=server/secrets/apns_auth_key.p8
TIGERDUCK_APNS_ENV=development
